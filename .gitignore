# Secrets - critical, this is why we're doing this
.env
*.env
.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter Notebooks
*.ipynb
.ipynb_checkpoints/

# Data files - your scraped output, don't want raw/full datasets committed
*.csv
!sample_*.csv
sample_az_top_foreclosure.csv

# Logs (you use logging with append filemode per your notifications.py setup)
*.log

# OS junk
.DS_Store
Thumbs.db

# VS Code settings (optional - only if you don't want to share editor config)
.vscode/